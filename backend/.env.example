# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration - Local
# For local development, use:
MONGODB_URI=mongodb://localhost:27017/flowbot

# MongoDB Configuration - Server/Production
# For production server, use format:
# MONGODB_URI=mongodb://username:password@server-ip:27017/database-name
# Example: MONGODB_URI=mongodb://bots:b0t5bots@127.0.0.1:27017/bots

# JWT Secret
JWT_SECRET=your-secret-key-change-this-in-production

# WhatsApp API endpoint for outbound agent messages
# Format: provider/account-id  (used in https://wa.message.co.il/api/{WHATSAPP_ENDPOINT}/send)
WHATSAPP_ENDPOINT=dialog360/65aec7ebf1a1d64f29645fd9

MESERGO_EMAIL_USERNAME=admin@chatgo.live
MESERGO_EMAIL_TOKEN=1aa14226-ceae-4104-ba86-899eca88631d
MESERGO_FROM_ADDRESS=admin@chatgo.live
